{
  "$schema": "https://tr.designtokens.org/format/",
  "typography": {
    "$type": "dimension",
    "fontFamily": {
      "$type": "fontFamily",
      "$value": "'Source Sans 3', sans-serif"
    },
    "fontWeight": {
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "bold": { "$value": 700 }
    },
    "size": {
      "sm": {
        "title": { "$value": "28px" },
        "subtitle": { "$value": "20px" },
        "header": { "$value": "20px" },
        "body": { "$value": "16px" },
        "caption": { "$value": "14px" }
      },
      "md": {
        "title": { "$value": "32px" },
        "subtitle": { "$value": "21px" },
        "header": { "$value": "21px" },
        "body": { "$value": "17px" },
        "caption": { "$value": "15px" }
      },
      "lg": {
        "title": { "$value": "36px" },
        "subtitle": { "$value": "22px" },
        "header": { "$value": "22px" },
        "body": { "$value": "18px" },
        "caption": { "$value": "16px" }
      }
    }
  }
}
