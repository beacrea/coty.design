{
  "$schema": "https://tr.designtokens.org/format/",
  "typography": {
    "$type": "dimension",
    "fontFamily": {
      "$type": "fontFamily",
      "$value": "'Source Sans 3', sans-serif"
    },
    "fontWeight": {
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "bold": { "$value": 700 }
    },
    "size": {
      "sm": {
        "title": { "$value": "30px" },
        "subtitle": { "$value": "22px" },
        "header": { "$value": "22px" },
        "body": { "$value": "18px" },
        "caption": { "$value": "16px" }
      },
      "md": {
        "title": { "$value": "34px" },
        "subtitle": { "$value": "24px" },
        "header": { "$value": "24px" },
        "body": { "$value": "19px" },
        "caption": { "$value": "17px" }
      },
      "lg": {
        "title": { "$value": "40px" },
        "subtitle": { "$value": "26px" },
        "header": { "$value": "26px" },
        "body": { "$value": "20px" },
        "caption": { "$value": "18px" }
      }
    }
  }
}
