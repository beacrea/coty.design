  "statusRules": {
    "@type": "StatusRule",
    "statusDefinitions": {
      "Proposed": "Articulated but not yet anchored in Tier A/B evidence.",
      "Active": "Plausible and internally observed; evidence mixed or incomplete.",
      "Emerging": "Early external evidence supports directionality; counter-evidence exists.",
      "Supported": "Multiple independent sources support; contradictions are bounded.",
      "Strongly supported": "Supported + repeatedly replicated across contexts; counter-evidence is edge-case or tool-generation specific.",
      "Contentious": "High-quality evidence exists on both sides; mechanism unclear.",
      "Refuted (for now)": "Best available Tier A/B evidence contradicts the claim in the relevant scope.",
      "Retired": "Claim is no longer useful or has been subsumed by a more precise claim."
    },
    "promotionThreshold": "At least 2 independent Tier A sources OR 1 Tier A + 2 Tier B sources directly support the claim's mechanism. At least 1 credible counter-source has been reviewed. The claim has at least one operational metric that can be measured internally.",
    "demotionThreshold": "A Tier A result contradicts the claim in the doctrine's stated scope and cannot be re-scoped without gutting the claim. OR internal measures consistently move opposite the prediction for 2 consecutive quarters. OR the claim cannot be translated into observable predictions.",
    "splitRule": "If both support and counter-evidence remain strong, split the claim by context rather than averaging them into mush."
  },
  "evidenceQualityRubric": [
    {
      "@type": "EvidenceTier",
      "tierLevel": "A",
      "description": "Peer-reviewed or strong preprint with methods + data; official datasets/benchmarks."
    },
    {
      "@type": "EvidenceTier",
      "tierLevel": "B",
      "description": "Vendor research with methods; reputable org reports."
    },
    {
      "@type": "EvidenceTier",
      "tierLevel": "C",
      "description": "High-quality journalism or practitioner essays with concrete examples."
    },
    {
      "@type": "EvidenceTier",
      "tierLevel": "D",
      "description": "Anecdotes (useful prompts for hypotheses; never decisive)."
    }
  ]
}