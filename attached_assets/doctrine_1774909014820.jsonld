      "shortName": "role-convergence",
      "title": "Roles converge upward in greenfield and small-team contexts",
      "statement": "In greenfield, startup, and small-team contexts, AI makes narrowly defined execution functions economically obsolete faster than it creates new narrow roles, increasing demand for generalists with architectural judgment.",
      "rationale": "Small teams already reward breadth. AI amplifies this by collapsing the cost of tasks that previously justified specialists. The result is fewer, broader roles—not a hollowed middle.",
      "status": "Emerging",
      "statusLastChanged": "v1.0.0",
      "splitFrom": "claim-5",
      "splitVersion": "v1.0.0",
