  "@type": "Doctrine",
  "@id": "https://underline.tech/doctrine/ontological-orchestration",
  "name": "Doctrine: Ontological Orchestration in AI-Assisted Development",
  "description": "A structured set of claims about how AI-assisted development is changing the nature of work, paired with explicit assumptions, supporting evidence, counter-evidence, and evaluation criteria. Evidence is graded using a four-tier quality rubric (A=peer-reviewed/benchmarks, B=vendor research with methods, C=quality journalism, D=anecdotes). Claims are promoted or demoted based on explicit thresholds and a split rule for contextual divergence.",
  "version": "v1.1.0",
  "dateCreated": "2025-12",
  "dateModified": "2026-03-30",
  "status": "Active",
  "reviewCadence": "Quarterly",
  "author": {
    "@type": "schema:Person",
    "name": "Coty Beasley",
    "schema:affiliation": {
      "@type": "schema:Organization",
      "name": "Underline Infrastructure",
      "description": "Telecommunications, software-driven platform"
    }
  },
  "thesis": "Technology roles are shifting from discrete execution to ontological orchestration: the definition, constraint, and sequencing of meaning in systems where execution is increasingly abundant.",
  "definitions": [
    {
      "@type": "Definition",
      "term": "Ontological orchestration",
      "description": "The act of defining what exists, what matters, how components relate, and what constitutes correctness in a system—before and during execution."
    },
    {
      "@type": "Definition",
      "term": "Harness",
      "description": "A structured package of intent, constraints, artifacts, and validation mechanisms that bounds and guides execution (human or agentic)."
    },
    {
      "@type": "Definition",
      "term": "Intent hypothesis",
      "description": "A falsifiable statement describing a believed problem, its context, constraints, and success criteria."
    },
    {
      "@type": "Definition",
      "term": "Situated authorship",
      "description": "Authorship determined by surface-area expertise and problem context rather than formal role."
    }
  ],
  "claims": [
    {
      "@type": "Claim",
      "@id": "#claim-1",
      "claimNumber": "1",
      "shortName": "execution-constraint",
      "title": "Execution is no longer the dominant constraint",
      "statement": "For most software-driven organizations, the cost of producing artifacts (code, designs, drafts) is falling faster than the cost of deciding what should exist and how it should behave.",
      "rationale": "AI systems dramatically reduce realization latency, enabling rapid generation and iteration. This amplifies the cost of poor framing and weak constraints.",
      "status": "Active",
      "statusLastChanged": "v0.1.0",
      "supportingSignals": [
        "Rapid artifact generation with minimal marginal cost",
        "Increased verification and correction overhead in mature systems",
        "Shift in effort toward review, alignment, and validation"
      ],
      "challenges": [
        "Expert slowdowns due to verification tax",
        "Tool brittleness in complex, stateful systems"
      ],
      "evaluationCriteria": [
        "Time spent framing vs implementing over time",
        "Ratio of rework due to misalignment vs technical defects"
      ],
      "evidence": [
        {
          "@type": "EvidenceReference",
          "sourceTitle": "The Mythical Man-Month",
          "sourceAuthor": "Frederick P. Brooks",
          "sourceDate": "1975",
          "tier": "A",
          "role": "supporting",
          "annotation": "foundational argument that communication and coordination, not coding, dominate software effort",
          "captureStatus": "placeholder",
          "archivePath": "src/evidence/claim-1/brooks-1975-mythical-man-month.md",
          "captureDate": "2026-03-30",
          "sharedWith": [],
          "summary": "Brooks's law demonstrates that adding developers to late projects makes them later because communication overhead, not coding, dominates software effort. This foundational insight prefigures the doctrine's claim that coordination and decision quality are the real constraints, a pattern AI amplifies by making execution even cheaper.",
          "captureNotes": "Foundational software engineering text. Book — requires manual capture of relevant excerpts."
        },
        {
          "@type": "EvidenceReference",
          "sourceTitle": "Code Complete",
          "sourceAuthor": "Steve McConnell",
          "sourceDate": "1993",
          "tier": "A",
          "role": "supporting",
          "annotation": "design decisions and requirements clarity matter more than raw coding speed",
          "captureStatus": "placeholder",
          "archivePath": "src/evidence/claim-1/mcconnell-1993-code-complete.md",
          "captureDate": "2026-03-30",
          "sharedWith": [],
          "summary": "McConnell's empirical data shows that defect cost escalates 10-100x when requirements errors propagate to implementation, establishing that design decisions and requirements clarity matter more than coding speed. This directly supports the claim that the dominant constraint has always been upstream of execution.",
          "captureNotes": "Comprehensive software construction guide. Book — requires manual capture of relevant excerpts."
        },
        {
          "@type": "EvidenceReference",
          "sourceTitle": "The Impact of AI on Developer Productivity: Evidence from GitHub Copilot",
          "sourceAuthor": "Sida Peng, Eirini Kalliamvakou, Peter Cihon, Mert Demirer",
          "sourceDate": "2023-02",
          "sourceUrl": "https://www.microsoft.com/en-us/research/publication/the-impact-of-ai-on-developer-productivity-evidence-from-github-copilot/",
          "tier": "A",
          "role": "supporting",
          "annotation": "55.8% speedup on bounded coding tasks; heterogeneous effects suggest execution is not the only variable",
          "captureStatus": "captured",
          "archivePath": "src/evidence/claim-1/microsoft-2023-copilot-productivity-rct.md",
          "captureDate": "2026-03-30",
          "sharedWith": [
            "claim-3"
          ],
          "summary": "A randomized controlled trial found GitHub Copilot users completed a bounded HTTP server task 55.8% faster than controls, but effects were heterogeneous across developer groups. The speed gain on isolated tasks combined with uneven benefits suggests execution acceleration is real but insufficient to address the harder constraints of verification and system-level reasoning.",
          "captureNotes": "Randomized controlled trial. Captured from Microsoft Research publication page."
        },
        {
          "@type": "EvidenceReference",
          "sourceTitle": "Measuring the Impact of Early-2025 AI on Experienced Open-Source Developer Productivity",
          "sourceAuthor": "Becker, Rush, Barnes, Rein",
          "sourceDate": "2025-07-10",
          "sourceUrl": "https://metr.org/blog/2025-07-10-early-2025-ai-experienced-os-dev-study/",
          "tier": "A",
          "role": "supporting",
          "annotation": "experienced devs slower with AI in mature codebases; validates verification and context as the bottleneck, not coding",
          "captureStatus": "pending",
          "archivePath": "src/evidence/claim-1/metr-2025-experienced-dev-ai-study.md",
          "captureDate": "2026-03-30",
          "sharedWith": [],
          "summary": "In a gold-standard RCT, experienced open-source developers using AI tools (Cursor + Claude) were approximately 19% slower on realistic 20min-4hr tasks in mature codebases, despite self-reporting 20-24% perceived speedups. This is the strongest evidence that verification, context management, and integration overhead — not coding — are the binding constraint in complex systems.",
          "captureNotes": "Rigorous RCT. Web page — requires manual capture (403 on automated fetch)."
        },
        {
