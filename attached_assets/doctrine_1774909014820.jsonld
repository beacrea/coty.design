    {
      "@type": "Claim",
      "@id": "#claim-2",
      "claimNumber": "2",
      "shortName": "ontological-architecture",
      "title": "Architecture becomes ontological, not just structural",
      "statement": "The primary architectural work shifts from pipelines and components to shared ontologies: vocabularies, invariants, constraints, and mental models.",
      "rationale": "Without shared meaning, faster execution increases divergence and coordination cost.",
      "status": "Active",
      "statusLastChanged": "v0.1.0",
      "supportingSignals": [
        "Need for registries, schemas, and canonical definitions",
        "Emergence of planning planes (intent, decision, execution, verification)"
      ],
      "challenges": [
        "Risk of over-formalization",
        "Cultural resistance to explicit modeling"
      ],
      "evaluationCriteria": [
        "Frequency of semantic vs technical disagreements",
        "Stability of interfaces and concepts over time"
      ],
      "evidence": [
        {
          "@type": "EvidenceReference",
          "sourceTitle": "Overview • Ontology",
          "sourceAuthor": "Palantir",
          "sourceUrl": "https://www.palantir.com/docs/foundry/ontology/overview",
          "tier": "B",
          "role": "supporting",
          "annotation": "semantic framework where business objects are defined once and reused across applications, collapsing integration complexity",
          "captureStatus": "pending",
          "archivePath": "src/evidence/claim-2/palantir-foundry-ontology-overview.md",
          "captureDate": "2026-03-30",
          "sharedWith": [],
          "summary": "Palantir's Foundry platform uses a semantic ontology where business objects are defined once and reused across all applications, eliminating per-application integration. A production-scale example of ontological architecture replacing structural wiring as the primary coordination mechanism.",
          "captureNotes": "Palantir Foundry documentation. Web page — requires manual capture (403 on automated fetch)."
        },
        {
          "@type": "EvidenceReference",
          "sourceTitle": "Ontologies • Overview",
          "sourceAuthor": "Palantir",
          "sourceUrl": "https://www.palantir.com/docs/foundry/ontologies/ontologies-overview",
          "tier": "B",
          "role": "supporting",
          "annotation": "shared meaning (not shared pipelines) enables coordination at scale",
          "captureStatus": "pending",
          "archivePath": "src/evidence/claim-2/palantir-ontologies-overview.md",
          "captureDate": "2026-03-30",
          "sharedWith": [],
          "summary": "Technical documentation showing how shared meaning structures (not shared data pipelines) enable coordination at scale. Demonstrates that defining relationships and types ontologically collapses integration complexity across applications and teams.",
          "captureNotes": "Technical documentation on building ontologies. Web page — requires manual capture (403 on automated fetch)."
        },
        {
          "@type": "EvidenceReference",
          "sourceTitle": "Ontology SDK (OSDK) • Overview",
          "sourceAuthor": "Palantir",
          "sourceUrl": "https://www.palantir.com/docs/foundry/ontology-sdk/overview",
          "tier": "B",
          "role": "supporting",
          "annotation": "code generation from ontological definitions accelerates agent development; define once semantically, generate automatically",
          "captureStatus": "pending",
          "archivePath": "src/evidence/claim-2/palantir-osdk-overview.md",
          "captureDate": "2026-03-30",
          "sharedWith": [],
          "summary": "The Ontology SDK generates application code directly from ontological definitions, accelerating agent and application development. Demonstrates the 'define once semantically, generate automatically' pattern that the doctrine predicts becomes dominant.",
          "captureNotes": "Developer SDK for ontology-driven applications. Web page — requires manual capture (403 on automated fetch)."
        },
        {
          "@type": "EvidenceReference",
          "sourceTitle": "Spec-Driven Development: From Code to Contract in the Age of AI",
          "sourceAuthor": "arXiv authors",
          "sourceDate": "2025",
          "sourceUrl": "https://arxiv.org/html/2602.00180v1",
          "tier": "A",
          "role": "supporting",
