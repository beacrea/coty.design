modules = ["nodejs-20", "postgresql-16"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Main Site"

[[workflows.workflow]]
name = "Main Site"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd portfolio && PORT=5000 npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 4200

[[ports]]
localPort = 5010
externalPort = 3003

[[ports]]
localPort = 24678
externalPort = 3002

[agent]
expertMode = true

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build", "--prefix", "portfolio"]
publicDir = "portfolio/dist"
run = ["npm", "run", "start", "--prefix", "portfolio"]

[nix]
channel = "stable-25_05"
packages = ["imagemagick"]
